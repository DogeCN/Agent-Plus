data: {"p":"response/fragments/-1/results","o":"SET","v":[{"url":"https://blog.gitcode.com/39065c1ee009e26c4ae75bcd8d4a66a1.html","title":"Lucene项目KNN图多线程搜索测试失败问题分析","snippet":"该测试用例主要验证K最近邻(KNN)图在多线程环境下的搜索功能 ... 多线程问题：测试用例在多线程环境下运行，这增加了结果的不确定性。当多个线程同时访问和修改图结构时，可能导致搜索路径的微小差异。","cite_index":null,"published_at":1751558400.0,"site_icon":"https://cdn.deepseek.com/site-icons/gitcode.com","site_name":"GitCode","query_indexes":[0]},{"url":"https://blog.gitcode.com/727701d6dfc814f205c61f6fe3785386.html","title":"Apache Lucene KNN图搜索多线程测试失败问题分析","snippet":"在Apache Lucene项目中，TestKnnGraph.testMultiThreadedSearch测试用例出现了随机性失败。该测试用例主要验证K最近邻(KNN)图搜索在多线程环境下的正确性。测试失败时 ... 多个搜索线程可能同时访问和修改图结构，这增加了实现的复杂性。","cite_index":null,"published_at":1750953600.0,"site_icon":"https://cdn.deepseek.com/site-icons/gitcode.com","site_name":"GitCode","query_indexes":[0]},{"url":"https://browse-export.arxiv.org/abs/2510.05137","title":"Demystifying deep search: a holistic evaluation with hint-free multi-hop questions and factorised metrics","snippet":"To address these issues, we present WebDetective, a benchmark of hint-free multi-hop questions paired with a controlled Wikipedia sandbox that ensures full traceability of model actions, and a holistic evaluation framework that separates search sufficiency, knowledge utilisation, and refusal behaviour.","cite_index":null,"published_at":1765296000.0,"site_icon":"https://cdn.deepseek.com/site-icons/arxiv.org","site_name":"arxiv.org","query_indexes":[0]},{"url":"https://help.aliyun.com/zh/open-search/industry-algorithm-edition/multiple-search","title":"多路搜索-智能开放搜索 OpenSearch(Open Search)-阿里云帮助中心","snippet":"多路搜索API允许在单次请求中并行发起最多N路独立的查询，并对各路召回的结果进行统一的排序和合并。可为每一路查询自定义召回数量、优先级，并对最终结果进行来源追溯，适用于需要融合文本、向量、不同索引或不同查询策略的复杂搜索场景。","cite_index":null,"published_at":1761580800.0,"site_icon":"https://cdn.deepseek.com/site-icons/aliyun.com","site_name":"阿里云文档中心","query_indexes":[0]},{"url":"https://cloud.tencent.cn/document/product/1772/115420","title":"知识引擎原子能力 多轮改写_腾讯云","snippet":"多轮改写（QueryRewrite）主要用于多轮对话中，进行指代消解和省略补全。使用本接口，无需输入prompt描述，根据对话历史即可生成更精确的用户查询。在应用场景上，本接口可应用于智能问答、对话式搜索等多种场景。","cite_index":null,"published_at":1757606400.0,"site_icon":"https://cdn.deepseek.com/site-icons/tencent.cn","site_name":"CSDN博客","query_indexes":[0]},{"url":"https://meilisearch.com.cn/docs/learn/engine/concat#concatenated-queries","title":"连接和拆分查询","snippet":"拆分的词在搜索查询中不被视为多个词，因为它们必须保持彼此相邻。 ### 示例 搜索 newspaper 时，它会拆分为 news 和 paper，而不是 new 和 spaper。包含被其他词分隔的 news 和 paper 的文档与搜索无关。","cite_index":null,"published_at":null,"site_icon":"https://cdn.deepseek.com/site-icons/meilisearch.com.cn","site_name":"meilisearch.com.cn","query_indexes":[0]},{"url":"https://www.alibabacloud.com/help/tc/open-search/industry-algorithm-edition/multimodal-search#topic-2129082","title":"電商行業模板-多路搜尋 - Alibaba Cloud","snippet":"OpenSearch的多路搜尋功能結合了文本搜尋和向量搜尋，做到了搜尋延遲和計算消耗低於OR邏輯情況下更高的準確性，並在搜題情境已經得到有效驗證。多路召回架構還可以使用到：圖片向量召回...","cite_index":null,"published_at":1776960000.0,"site_icon":"https://cdn.deepseek.com/site-icons/alibabacloud.com","site_name":"Alibaba Cloud","query_indexes":[0]},{"url":"https://www.meilisearch.com/blog/introducing-multi-search?utm_source=release-post&utm_id=cloud-announcement&utm_content=earch-as-a-service","title":"Introducing multi-index search","snippet":"We have introduced a/multi-search route that allows searching in multiple indexes with a single HTTP request. Suppose we have two indexes: movies and actors. Using the /multi-search endpoint, we can search for the name of an actress and retrieve both her biography and movies in the search results.","cite_index":null,"published_at":1756051200.0,"site_icon":"https://cdn.deepseek.com/site-icons/meilisearch.com","site_name":"Meilisearch","query_indexes":[0]},{"url":"https://www.algolia.com/old-docs/api-reference/api-methods/multiple-queries/?client=ruby","title":"Search multiple indices API reference | Algolia","snippet":"Perform a search on several indices at the same time, with one method call. ... - You want to target one index and send it multiple queries, where, for example, each query contains different settings or filters, or the query itself is slightly adjusted.","cite_index":null,"published_at":1758729600.0,"site_icon":"https://cdn.deepseek.com/site-icons/algolia.com","site_name":"Algolia","query_indexes":[0]},{"url":"https://arxiv.org/html/2602.23184","title":"MTRAG-UN: A Benchmark for Open Challenges in Multi-Turn RAG Conversations","snippet":"We present MTRAG-UN, a benchmark for exploring open challenges in multi-turn retrieval augmented generation, a popular use of large language models. ... In a multi-turn conversation, later turns can implicitly reference information in earlier turns. Such questions are considered non-standalone as they require the prior turns to be understood.","cite_index":null,"published_at":null,"site_icon":"https://cdn.deepseek.com/site-icons/arxiv.org","site_name":"arXiv","query_indexes":[0]},{"url":"https://aitopics.org/doc/arxivorg:79999854","title":"AITopics | MTRAG: A Multi-Turn Conversational Benchmark for Evaluating Retrieval-Augmented Generation Systems","snippet":"We present MTRAG: an end-to-end human-generated multi-turn RAG benchmark that reflects several real-world properties across diverse dimensions for evaluating the full RAG pipeline. MTRAG contains 110 conversations averaging 7.7 turns","cite_index":null,"published_at":1736092800.0,"site_icon":"https://cdn.deepseek.com/site-icons/aitopics.org","site_name":"AITopics","query_indexes":[0]},{"url":"https://modelscope.cn/datasets/MiniMax/MR-NIAH/resolve/master/README.md","title":"","snippet":"Multi-Round Needles-In-A-Haystack (MR-NIAH) is an evaluation framework designed to assess long-context retrieval performance in large language models (LLMs). It serves as a crucial benchmark for retrieval tasks in long multi-turn dialogue contexts, revealing fundamental capabilities necessary for building lifelong companion AI assistants.","cite_index":null,"published_at":null,"site_icon":"https://cdn.deepseek.com/site-icons/modelscope.cn","site_name":"ModelScope","query_indexes":[0]},{"url":"https://ar5iv.labs.arxiv.org/html/2510.16712","title":"The Chameleon Nature of LLMs: Quantifying Multi-Turn Stance Instability in Search-Enabled Language Models","snippet":"We present the first systematic investigation of \"chameleon behavior\" in LLMs: their alarming tendency to shift stances when presented with contradictory questions in multi-turn conversations (especially in search-enabled LLMs). ... Although prior research emphasizes single-turn accuracy, multi-turn stance consistency in search-enabled settings remains largely unexamined.","cite_index":null,"published_at":null,"site_icon":"https://cdn.deepseek.com/site-icons/arxiv.org","site_name":"arXiv","query_indexes":[0]},{"url":"https://www.evalops.dev/docs/multi-turn-eval","title":"Docs — EvalOps","snippet":"Agents operate across multiple turns. A support agent clarifies, retrieves, and resolves over 3-8 turns. ... Multi-turn evaluation scores the full conversation thread: did the agent accomplish the task? Did it take a reasonable number of steps? Did it stay on topic and follow policy?","cite_index":null,"published_at":null,"site_icon":"https://cdn.deepseek.com/site-icons/evalops.dev","site_name":"EvalOps","query_indexes":[0]},{"url":"https://llmdocs.deepchecks.com/docs/multi-turn-agent-demo-google-adk-academic-researcher","title":"Multi-Turn Agent Demo: Google ADK Academic Researcher - Deepchecks","snippet":"This demo walks through evaluating and debugging a multi-agent, multi-turn research assistant built on Google ADK. The application analyzes seminal academic papers, retrieves recent citing literature from the web, and proposes future research directions - and it does so across conversations that can span several back-and-forth turns with the user.","cite_index":null,"published_at":null,"site_icon":"https://cdn.deepseek.com/site-icons/deepchecks.com","site_name":"Deepchecks","query_indexes":[0]},{"url":"https://deepwiki.com/CURRENTF/Sparse-vLLM/6.3-scbench-evaluation","title":"SCBench Evaluation | CURRENTF/Sparse-vLLM | DeepWiki","snippet":"1. Multi-Turn Evaluation In this mode, the model engages in a continuous conversation. Each subsequent turn includes the history of previous turns, testing the engine's ability to maintain and update the KV cache incrementally.","cite_index":null,"published_at":1775664000.0,"site_icon":"https://cdn.deepseek.com/site-icons/deepwiki.com","site_name":"DeepWiki","query_indexes":[0]},{"url":"https://cloud.baidu.com/doc/AIHC/s/am7j0h787","title":"快速部署联网搜索SearXNG插件","snippet":"联网搜索的实现方式 百舸联网搜索采用多轮搜索和AI Agent智能协同机制，实现精准的信息提取： - 第一步原始Query查询：基于用户的原始查询（Query），进行全网搜索，获取初步搜索结果。 - 第二步智能Query扩写：智能扩写Agent，对初始Query进行优化扩写，并再次执行全网搜索，获取更多结果。（可重复多次）","cite_index":null,"published_at":1763913600.0,"site_icon":"https://cdn.deepseek.com/site-icons/baidu.com","site_name":"百度智能云","query_indexes":[0]},{"url":"https://www.npmjs.com/package/agent-local-search","title":"agent-local-search","snippet":"传统方式需要多轮搜索、逐个打开链接。agent-search 一次并发搜索多个关键词，自动重排序返回最相关结果。 场景二：快速查阅资料 \"帮我看看最近关于 AI 编程有什么新闻？\"","cite_index":null,"published_at":1776268800.0,"site_icon":"https://cdn.deepseek.com/site-icons/npmjs.com","site_name":"NPM","query_indexes":[0]},{"url":"https://support.huaweicloud.com/usermanual-koosearch/koosearch_06_8015.html","title":"深度研究","snippet":"用户可以在前端页面上配置模型，进行任务规划的多轮交互式修改，并选择“研究报告”模式。系统后端将根据用户配置，执行任务规划与深度研究的逻辑，最终生成详细的大纲和研究报告。","cite_index":null,"published_at":1772985600.0,"site_icon":"https://cdn.deepseek.com/site-icons/huaweicloud.com","site_name":"华为云帮助中心","query_indexes":[0]},{"url":"https://rpahelpcenter.bazhuayu.com/helpcenter/docs/PpKkq8","title":"单网页多关键词搜索-Excel","snippet":"打开指定网页，启动Excel文件，读取Excel里所有关键词。每读取一个关键词就填写一次输入框，直到所有关键词都搜索完毕 ... 依次循环 Excel 中的每一个关键词，循环的 Excel 对象选择刚才创建的“搜索关键词”，并且把当前循环到的关键词命名为当前关键词。","cite_index":null,"published_at":1757606400.0,"site_icon":"https://cdn.deepseek.com/site-icons/bazhuayu.com","site_name":"八爪鱼采集器","query_indexes":[0]},{"url":"https://www.alibabacloud.com/help/en/open-search/industry-algorithm-edition/multiple-search-go","title":"Multi-path search - Alibaba Cloud","snippet":"Multi-path search runs up to N independent queries in parallel within a single request, then merges and uniformly ranks the results. Each query path can have its own retrieval count and priority, and you can trace which path contributed each result in the final output.","cite_index":null,"published_at":1774886400.0,"site_icon":"https://cdn.deepseek.com/site-icons/alibabacloud.com","site_name":"Alibaba Cloud","query_indexes":[0]},{"url":"https://pub.dev/packages/ddgs","title":"ddgs | Dart package","snippet":"A professional metasearch library that aggregates results from multiple web search engines including DuckDuckGo, Google, Bing, Brave, Ecosia, Qwant, and more. ... A professional metasearch library that aggregates results from multiple web search engines including DuckDuckGo, Google, Bing, Brave, and more.","cite_index":null,"published_at":1759939200.0,"site_icon":"https://cdn.deepseek.com/site-icons/pub.dev","site_name":"Dart packages","query_indexes":[0]},{"url":"https://www.npmjs.com/package/browser-web-search","title":"browser-web-search","snippet":"一行命令，搜遍全网 — 为 AI Agent 而生的多平台内容搜索工具 ... BWS 把 55 个主流平台的搜索接口封装成统一的命令行 API，让 Agent 直接拿到结构化 JSON，无需任何额外配置。","cite_index":null,"published_at":1777132800.0,"site_icon":"https://cdn.deepseek.com/site-icons/npmjs.com","site_name":"NPM","query_indexes":[0]}]}

