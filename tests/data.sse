data: {"p":"response","o":"BATCH","v":[{"p":"fragments","o":"APPEND","v":[{"id":5,"type":"TOOL_OPEN","status":"WIP","result":{"url":"https://blog.gitcode.com/39065c1ee009e26c4ae75bcd8d4a66a1.html","title":"Lucene项目KNN图多线程搜索测试失败问题分析","snippet":"该测试用例主要验证K最近邻(KNN)图在多线程环境下的搜索功能 ... 多线程问题：测试用例在多线程环境下运行，这增加了结果的不确定性。当多个线程同时访问和修改图结构时，可能导致搜索路径的微小差异。","cite_index":null,"published_at":1751558400.0,"site_icon":"https://cdn.deepseek.com/site-icons/gitcode.com","site_name":"GitCode","query_indexes":[0]},"reference":{"id":3,"type":"TOOL_SEARCH"},"stage_id":2},{"id":6,"type":"TOOL_OPEN","status":"WIP","result":{"url":"https://browse-export.arxiv.org/abs/2510.05137","title":"Demystifying deep search: a holistic evaluation with hint-free multi-hop questions and factorised metrics","snippet":"To address these issues, we present WebDetective, a benchmark of hint-free multi-hop questions paired with a controlled Wikipedia sandbox that ensures full traceability of model actions, and a holistic evaluation framework that separates search sufficiency, knowledge utilisation, and refusal behaviour.","cite_index":null,"published_at":1765296000.0,"site_icon":"https://cdn.deepseek.com/site-icons/arxiv.org","site_name":"arxiv.org","query_indexes":[0]},"reference":{"id":3,"type":"TOOL_SEARCH"},"stage_id":2},{"id":7,"type":"TOOL_OPEN","status":"WIP","result":{"url":"https://help.aliyun.com/zh/open-search/industry-algorithm-edition/multiple-search","title":"多路搜索-智能开放搜索 OpenSearch(Open Search)-阿里云帮助中心","snippet":"多路搜索API允许在单次请求中并行发起最多N路独立的查询，并对各路召回的结果进行统一的排序和合并。可为每一路查询自定义召回数量、优先级，并对最终结果进行来源追溯，适用于需要融合文本、向量、不同索引或不同查询策略的复杂搜索场景。","cite_index":null,"published_at":1761580800.0,"site_icon":"https://cdn.deepseek.com/site-icons/aliyun.com","site_name":"阿里云文档中心","query_indexes":[0]},"reference":{"id":3,"type":"TOOL_SEARCH"},"stage_id":2},{"id":8,"type":"TOOL_OPEN","status":"WIP","result":{"url":"https://cloud.tencent.cn/document/product/1772/115420","title":"知识引擎原子能力 多轮改写_腾讯云","snippet":"多轮改写（QueryRewrite）主要用于多轮对话中，进行指代消解和省略补全。使用本接口，无需输入prompt描述，根据对话历史即可生成更精确的用户查询。在应用场景上，本接口可应用于智能问答、对话式搜索等多种场景。","cite_index":null,"published_at":1757606400.0,"site_icon":"https://cdn.deepseek.com/site-icons/tencent.cn","site_name":"CSDN博客","query_indexes":[0]},"reference":{"id":3,"type":"TOOL_SEARCH"},"stage_id":2},{"id":9,"type":"TOOL_OPEN","status":"WIP","result":{"url":"https://arxiv.org/html/2602.23184","title":"MTRAG-UN: A Benchmark for Open Challenges in Multi-Turn RAG Conversations","snippet":"We present MTRAG-UN, a benchmark for exploring open challenges in multi-turn retrieval augmented generation, a popular use of large language models. ... In a multi-turn conversation, later turns can implicitly reference information in earlier turns. Such questions are considered non-standalone as they require the prior turns to be understood.","cite_index":null,"published_at":null,"site_icon":"https://cdn.deepseek.com/site-icons/arxiv.org","site_name":"arXiv","query_indexes":[0]},"reference":{"id":3,"type":"TOOL_SEARCH"},"stage_id":2},{"id":10,"type":"TOOL_OPEN","status":"WIP","result":{"url":"https://aitopics.org/doc/arxivorg:79999854","title":"AITopics | MTRAG: A Multi-Turn Conversational Benchmark for Evaluating Retrieval-Augmented Generation Systems","snippet":"We present MTRAG: an end-to-end human-generated multi-turn RAG benchmark that reflects several real-world properties across diverse dimensions for evaluating the full RAG pipeline. MTRAG contains 110 conversations averaging 7.7 turns","cite_index":null,"published_at":1736092800.0,"site_icon":"https://cdn.deepseek.com/site-icons/aitopics.org","site_name":"AITopics","query_indexes":[0]},"reference":{"id":3,"type":"TOOL_SEARCH"},"stage_id":2},{"id":11,"type":"TOOL_OPEN","status":"WIP","result":{"url":"https://cloud.baidu.com/doc/AIHC/s/am7j0h787","title":"快速部署联网搜索SearXNG插件","snippet":"联网搜索的实现方式 百舸联网搜索采用多轮搜索和AI Agent智能协同机制，实现精准的信息提取： - 第一步原始Query查询：基于用户的原始查询（Query），进行全网搜索，获取初步搜索结果。 - 第二步智能Query扩写：智能扩写Agent，对初始Query进行优化扩写，并再次执行全网搜索，获取更多结果。（可重复多次）","cite_index":null,"published_at":1763913600.0,"site_icon":"https://cdn.deepseek.com/site-icons/baidu.com","site_name":"百度智能云","query_indexes":[0]},"reference":{"id":3,"type":"TOOL_SEARCH"},"stage_id":2},{"id":12,"type":"TOOL_OPEN","status":"WIP","result":null,"reference":null,"stage_id":2},{"id":13,"type":"TOOL_OPEN","status":"WIP","result":null,"reference":null,"stage_id":2},{"id":14,"type":"TOOL_OPEN","status":"WIP","result":{"url":"https://pub.dev/packages/ddgs","title":"ddgs | Dart package","snippet":"A professional metasearch library that aggregates results from multiple web search engines including DuckDuckGo, Google, Bing, Brave, Ecosia, Qwant, and more. ... A professional metasearch library that aggregates results from multiple web search engines including DuckDuckGo, Google, Bing, Brave, and more.","cite_index":null,"published_at":1759939200.0,"site_icon":"https://cdn.deepseek.com/site-icons/pub.dev","site_name":"Dart packages","query_indexes":[0]},"reference":{"id":3,"type":"TOOL_SEARCH"},"stage_id":2}]},{"p":"has_pending_fragment","o":"SET","v":false}]}

